{
  "name": "ultimate-tab-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/build-sw.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ai": "esbuild scripts/test-ai-sort.ts --bundle --platform=node --format=cjs --define:import.meta.env.VITE_ANTHROPIC_API_KEY=process.env.VITE_ANTHROPIC_API_KEY --outfile=scripts/.test-ai.cjs && node --env-file=.env scripts/.test-ai.cjs"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^3.2.7"
  }
}
